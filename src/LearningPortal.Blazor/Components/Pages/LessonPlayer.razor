@page "/learn/{CourseSlug}/lessons/{LessonId:guid}"
@attribute [Authorize]
@rendermode InteractiveServer
@inject LearningPortalApiClient ApiClient
@inject NavigationManager Navigation

<PageTitle>Learning | Learning Portal</PageTitle>
@if (_loading) { <LoadingState Message="Loading lesson…" /> }
else if (!string.IsNullOrWhiteSpace(_error)) { <div class="feedback error" role="alert">@_error</div> }
else if (_player is not null)
{
    <PageHeader Eyebrow="@_player.CourseTitle" Title="@_player.LessonTitle" Description="@($"{_player.Progress.CompletedLessonCount} of {_player.Progress.TotalPublishedLessonCount} lessons complete ({_player.Progress.CompletionPercentage}%)")" />
    @if (_player.Progress.IsCompleted) { <div class="feedback success" role="status">Course completed.</div> }
    <div class="learning-player">
        <aside class="lesson-sidebar"><h2>Lessons</h2><ol>@foreach (var lesson in _player.Lessons) { <li class="@(lesson.IsCurrent ? "current" : string.Empty)"><a href="@($"/learn/{_player.CourseSlug}/lessons/{lesson.Id}")">@lesson.Order. @lesson.Title</a> <StatusBadge Text="@lesson.ProgressStatus" /></li> }</ol></aside>
        <section class="lesson-content">
            @if (_player.LessonType == "Article") { @((MarkupString)(_player.MarkdownHtml ?? string.Empty)) }
            else if (_player.LessonType == "Video" && _player.SourceUrl is not null) { <LessonVideoPlayer Title="@_player.LessonTitle" SourceUrl="@_player.SourceUrl" EmbedUrl="@_player.EmbedUrl" IsDirectVideo="@_player.IsDirectVideo" VideoProvider="Video" /> }
            else if (_player.LessonType == "Pdf" && _player.SourceUrl is not null) { <LessonPdfViewer SourceUrl="@_player.SourceUrl" /> }
            else if (_player.SourceUrl is not null) { <a class="button button-primary" href="@_player.SourceUrl" target="_blank" rel="noopener noreferrer">Open external resource</a> }
            <div class="course-actions">
                <a class="button" data-testid="start-ai-tutor"
                   href="@($"/ai-tutor?courseId={_player.CourseId:D}&lessonId={_player.LessonId:D}")">Ask about this lesson</a>
                @if (_player.PreviousLessonId is Guid previous) { <a class="button" href="@($"/learn/{CourseSlug}/lessons/{previous}")">Previous</a> }
                <button class="button button-primary" data-testid="complete-lesson"
                        disabled="@_completing" @onclick="CompleteAsync">Mark complete</button>
                @if (_player.NextLessonId is Guid next) { <a class="button" data-testid="next-lesson" href="@($"/learn/{CourseSlug}/lessons/{next}")">Next</a> }
            </div>
            @if (_quizzes.Count > 0)
            {
                <section aria-labelledby="course-assessments-heading">
                    <h2 id="course-assessments-heading">Course assessments</h2>
                    @foreach (var quiz in _quizzes)
                    {
                        <div class="course-actions">
                            <span>
                                <strong>@quiz.Title</strong>
                                @if (quiz.IsRequired)
                                {
                                    <StatusBadge Text="Required" Tone="primary" />
                                }
                            </span>
                            <a class="button button-primary"
                               data-testid="start-quiz"
                               href="@($"/learn/{CourseSlug}/quizzes/{quiz.Id:D}")">
                                Open quiz
                            </a>
                        </div>
                    }
                </section>
            }
        </section>
    </div>
}

@code {
    [Parameter] public string CourseSlug { get; set; } = string.Empty;
    [Parameter] public Guid LessonId { get; set; }
    private LessonPlayerResponse? _player;
    private IReadOnlyList<QuizListItemResponse> _quizzes = [];
    private string? _error;
    private bool _loading = true;
    private bool _completing;
    protected override async Task OnParametersSetAsync()
    {
        _loading = true; _error = null;
        try
        {
            _player = await ApiClient.GetLessonPlayerAsync(CourseSlug, LessonId);
            await ApiClient.AccessLessonAsync(_player.EnrollmentId, LessonId);
            _quizzes = await ApiClient.GetCourseQuizzesForLearnerAsync(_player.CourseId);
        }
        catch (ApiProblemException exception) { _error = exception.Message; }
        finally { _loading = false; }
    }
    private async Task CompleteAsync()
    {
        if (_player is null) return; _completing = true; _error = null;
        try { var result = await ApiClient.CompleteLessonAsync(_player.EnrollmentId, LessonId); if (result.NextLessonId is Guid next) Navigation.NavigateTo($"/learn/{CourseSlug}/lessons/{next}"); else await OnParametersSetAsync(); }
        catch (ApiProblemException exception) { _error = exception.Message; }
        finally { _completing = false; }
    }
}
