@page "/admin/instructor-eligibility"
@attribute [Authorize(Roles = ApplicationRoles.Administrator)]
@rendermode InteractiveServer
@inject LearningPortalApiClient ApiClient

<PageTitle>Instructor eligibility administration | Learning Portal</PageTitle>

<AuthenticatedContent Roles="@ApplicationRoles.Administrator">
    <PageHeader Eyebrow="Administration"
                Title="Instructor eligibility"
                Description="Review qualifications, recalculate results, and assign matching eligible instructors." />

    @if (_loading)
    {
        <LoadingState Message="Loading eligibility administration…" />
    }
    else
    {
        @if (_message is not null)
        {
            <div class="feedback success" role="status">@_message</div>
        }
        @if (_error is not null)
        {
            <div class="feedback error" role="alert">@_error</div>
        }

        <section class="app-card">
            <h2>Recalculate user eligibility</h2>
            <label>
                User
                <select @bind="_selectedUserId">
                    <option value="">Select user</option>
                    @foreach (var user in _users)
                    {
                        <option value="@user.Id">@user.DisplayName (@user.Email)</option>
                    }
                </select>
            </label>
            <button class="button"
                    type="button"
                    disabled="@(_saving || _selectedUserId is null)"
                    @onclick="RecalculateAsync">
                @(_saving ? "Recalculating…" : "Recalculate")
            </button>
        </section>

        <section class="app-card">
            <h2>Eligible instructors by skill</h2>
            <label>
                Skill
                <select @bind="_selectedSkillId" @bind:after="LoadEligibleAsync">
                    <option value="">Select skill</option>
                    @foreach (var skill in _skills)
                    {
                        <option value="@skill.Id">@skill.Name</option>
                    }
                </select>
            </label>
            @if (_selectedSkillId is null)
            {
                <p>Select a skill to review eligible instructors.</p>
            }
            else if (_eligible.Count == 0)
            {
                <EmptyState Title="No eligible instructors"
                            Description="No enabled user currently qualifies for this skill." />
            }
            else
            {
                <div class="table-scroll">
                    <table>
                        <thead>
                            <tr><th>Name</th><th>Best score</th><th>Qualified</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var item in _eligible)
                            {
                                <tr>
                                    <td>@item.DisplayName</td>
                                    <td>@item.BestPercentage%</td>
                                    <td>@item.QualifiedAtUtc.ToLocalTime().ToString("d")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>

        <section class="app-card">
            <h2>Assign course instructor</h2>
            <p>Only instructors eligible for the selected course skill are offered.</p>
            <label>
                Course
                <select @bind="_selectedCourseId" @bind:after="CourseChangedAsync">
                    <option value="">Select course</option>
                    @foreach (var course in _courses.Where(course => course.SkillId is not null))
                    {
                        <option value="@course.Id">@course.Title (@course.Status)</option>
                    }
                </select>
            </label>
            <label>
                Eligible instructor
                <select @bind="_selectedInstructorId"
                        disabled="@(_selectedCourseId is null || _eligible.Count == 0)">
                    <option value="">Select eligible instructor</option>
                    @foreach (var item in _eligible)
                    {
                        <option value="@item.UserId">@item.DisplayName (@item.BestPercentage%)</option>
                    }
                </select>
            </label>
            <button class="button button-primary"
                    type="button"
                    disabled="@(_saving || _selectedCourseId is null || _selectedInstructorId is null)"
                    @onclick="AssignAsync">
                @(_saving ? "Assigning…" : "Assign instructor")
            </button>
        </section>
    }
</AuthenticatedContent>

@code {
    private IReadOnlyList<SkillResponse> _skills = [];
    private IReadOnlyList<EligibleInstructorResponse> _eligible = [];
    private IReadOnlyCollection<UserResponse> _users = [];
    private IReadOnlyCollection<CourseListItemResponse> _courses = [];
    private Guid? _selectedUserId;
    private Guid? _selectedSkillId;
    private Guid? _selectedCourseId;
    private Guid? _selectedInstructorId;
    private bool _loading = true;
    private bool _saving;
    private string? _error;
    private string? _message;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var usersTask = ApiClient.GetUsersAsync(new() { PageSize = 100 });
            var coursesTask = ApiClient.GetCoursesAsync(new() { PageSize = 100 });
            var skillsTask = ApiClient.GetSkillsAsync();
            await Task.WhenAll(usersTask, coursesTask, skillsTask);
            _users = usersTask.Result.Items;
            _courses = coursesTask.Result.Items;
            _skills = skillsTask.Result;
        }
        catch (ApiProblemException exception)
        {
            _error = exception.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadEligibleAsync()
    {
        _eligible = [];
        _selectedInstructorId = null;
        if (_selectedSkillId is not Guid skillId)
        {
            return;
        }

        try
        {
            _eligible = await ApiClient.GetEligibleInstructorsAsync(skillId);
        }
        catch (ApiProblemException exception)
        {
            _error = exception.Message;
        }
    }

    private async Task CourseChangedAsync()
    {
        var course = _courses.FirstOrDefault(item => item.Id == _selectedCourseId);
        _selectedSkillId = course?.SkillId;
        await LoadEligibleAsync();
    }

    private async Task RecalculateAsync()
    {
        if (_selectedUserId is not Guid userId)
        {
            return;
        }

        _saving = true;
        _message = null;
        _error = null;
        try
        {
            await ApiClient.RecalculateInstructorEligibilityAsync(userId);
            _message = "Eligibility recalculated.";
        }
        catch (ApiProblemException exception)
        {
            _error = exception.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task AssignAsync()
    {
        if (_selectedCourseId is not Guid courseId
            || _selectedInstructorId is not Guid instructorId)
        {
            return;
        }

        _saving = true;
        _message = null;
        _error = null;
        try
        {
            var course = await ApiClient.GetCourseByIdAsync(courseId);
            await ApiClient.AssignCourseInstructorAsync(
                courseId,
                new(instructorId, course.RowVersion));
            _message = "Instructor assigned.";
        }
        catch (ApiProblemException exception)
        {
            _error = exception.Message;
        }
        finally
        {
            _saving = false;
        }
    }
}
