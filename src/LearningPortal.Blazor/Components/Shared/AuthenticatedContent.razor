<AuthorizeView Roles="@Roles">
    <Authorized>
        @ChildContent
    </Authorized>
    <NotAuthorized>
        <RedirectToAccessDenied />
    </NotAuthorized>
</AuthorizeView>

@code {
    /// <summary>Gets or sets an optional comma-delimited list of allowed roles.</summary>
    [Parameter]
    public string? Roles { get; set; }

    /// <summary>Gets or sets the content rendered for an authorized user.</summary>
    [Parameter, EditorRequired]
    public required RenderFragment ChildContent { get; set; }
}
