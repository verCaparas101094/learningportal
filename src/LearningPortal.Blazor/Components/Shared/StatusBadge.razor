<span class="status-badge @ToneClass">@Text</span>

@code {
    /// <summary>Gets or sets the text displayed by the badge.</summary>
    [Parameter, EditorRequired]
    public required string Text { get; set; }

    /// <summary>Gets or sets the semantic tone: neutral, primary, success, warning, or danger.</summary>
    [Parameter]
    public string Tone { get; set; } = "neutral";

    private string ToneClass => Tone.ToLowerInvariant() switch
    {
        "primary" => "primary",
        "success" => "success",
        "warning" => "warning",
        "danger" => "danger",
        _ => "neutral"
    };
}
