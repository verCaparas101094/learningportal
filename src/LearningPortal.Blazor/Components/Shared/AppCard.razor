<section class="app-card @AdditionalClass">
    @ChildContent
</section>

@code {
    /// <summary>Gets or sets optional additional CSS classes.</summary>
    [Parameter]
    public string? AdditionalClass { get; set; }

    /// <summary>Gets or sets the content displayed inside the card.</summary>
    [Parameter, EditorRequired]
    public required RenderFragment ChildContent { get; set; }
}
