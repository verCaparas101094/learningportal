@inherits LayoutComponentBase
@inject NavigationManager Navigation

<div class="app-shell @(_sidebarCollapsed ? "sidebar-collapsed" : string.Empty)">
    <aside id="portal-sidebar"
           class="sidebar @(_mobileSidebarOpen ? "mobile-open" : string.Empty)"
           aria-label="Primary navigation">
        <div class="brand">
            <span class="brand-mark" aria-hidden="true">LP</span>
            <span class="brand-copy">
                <strong>Learning Portal</strong>
                <small>Enterprise learning</small>
            </span>
        </div>

        <nav class="sidebar-navigation">
            <AuthorizeView Roles="@ApplicationRoles.Student">
                <NavigationSection Title="Learner">
                    <NavLink class="sidebar-link" href="/" Match="NavLinkMatch.All">
                        <span aria-hidden="true">⌂</span><span class="link-label">Dashboard</span>
                    </NavLink>
                    <NavLink class="sidebar-link" href="/my-courses">
                        <span aria-hidden="true">▤</span><span class="link-label">My Courses</span>
                    </NavLink>
                    <NavLink class="sidebar-link" href="/catalog">
                        <span aria-hidden="true">□</span><span class="link-label">Catalog</span>
                    </NavLink>
                    <NavLink class="sidebar-link" href="/my-learning">
                        <span aria-hidden="true">✓</span><span class="link-label">My Learning</span>
                    </NavLink>
                    <NavLink class="sidebar-link" href="/my-instructor-eligibility">
                        <span aria-hidden="true">★</span><span class="link-label">Instructor Eligibility</span>
                    </NavLink>
                    <NavLink class="sidebar-link" href="/certificates" style="display:none">
                        <span aria-hidden="true">◇</span><span class="link-label">Certificates</span>
                    </NavLink>
                    <NavLink class="sidebar-link" href="/achievements" style="display:none">
                        <span aria-hidden="true">☆</span><span class="link-label">Achievements</span>
                    </NavLink>
                    <NavLink class="sidebar-link" href="/calendar" style="display:none">
                        <span aria-hidden="true">□</span><span class="link-label">Calendar</span>
                    </NavLink>
                    <NavLink class="sidebar-link" href="/messages" style="display:none">
                        <span aria-hidden="true">✉</span><span class="link-label">Messages</span>
                    </NavLink>
                    <NavLink class="sidebar-link" href="/ai-tutor">
                        <span aria-hidden="true">✦</span><span class="link-label">AI Tutor</span>
                    </NavLink>
                </NavigationSection>
            </AuthorizeView>

            <AuthorizeView Roles="@ApplicationRoles.Instructor">
                <NavigationSection Title="Instructor">
                    <NavLink class="sidebar-link" href="/courses">
                        <span aria-hidden="true">▤</span><span class="link-label">Courses</span>
                    </NavLink>
                    <NavLink class="sidebar-link" href="/my-courses">
                        <span aria-hidden="true">▤</span><span class="link-label">My Courses</span>
                    </NavLink>
                    <NavLink class="sidebar-link" href="/analytics" style="display:none">
                        <span aria-hidden="true">⌁</span><span class="link-label">Analytics</span>
                    </NavLink>
                </NavigationSection>
            </AuthorizeView>

            <AuthorizeView Roles="@ApplicationRoles.Administrator">
                <NavigationSection Title="Administrator">
                    <NavLink class="sidebar-link" href="/" Match="NavLinkMatch.All">
                        <span aria-hidden="true">⌂</span><span class="link-label">Dashboard</span>
                    </NavLink>
                    <NavLink class="sidebar-link" href="/users">
                        <span aria-hidden="true">♙</span><span class="link-label">Users</span>
                    </NavLink>
                    <NavLink class="sidebar-link" href="/courses">
                        <span aria-hidden="true">▤</span><span class="link-label">Courses</span>
                    </NavLink>
                    <NavLink class="sidebar-link" href="/lessons" style="display:none">
                        <span aria-hidden="true">≡</span><span class="link-label">Lessons</span>
                    </NavLink>
                    <NavLink class="sidebar-link" href="/enrollments" style="display:none">
                        <span aria-hidden="true">✓</span><span class="link-label">Enrollments</span>
                    </NavLink>
                    <NavLink class="sidebar-link" href="/quizzes" style="display:none">
                        <span aria-hidden="true">?</span><span class="link-label">Quizzes</span>
                    </NavLink>
                    <NavLink class="sidebar-link" href="/admin/instructor-eligibility">
                        <span aria-hidden="true">★</span><span class="link-label">Instructor Eligibility</span>
                    </NavLink>
                    <NavLink class="sidebar-link" href="/admin/ai-tutor">
                        <span aria-hidden="true">AI</span><span class="link-label">AI Tutor Health</span>
                    </NavLink>
                    <NavLink class="sidebar-link" href="/certificates" style="display:none">
                        <span aria-hidden="true">◇</span><span class="link-label">Certificates</span>
                    </NavLink>
                    <NavLink class="sidebar-link" href="/analytics" style="display:none">
                        <span aria-hidden="true">⌁</span><span class="link-label">Analytics</span>
                    </NavLink>
                    <NavLink class="sidebar-link" href="/settings" style="display:none">
                        <span aria-hidden="true">⚙</span><span class="link-label">Settings</span>
                    </NavLink>
                </NavigationSection>
            </AuthorizeView>
        </nav>

        <button class="collapse-button"
                type="button"
                title="@(_sidebarCollapsed ? "Expand sidebar" : "Collapse sidebar")"
                aria-controls="portal-sidebar"
                aria-expanded="@(!_sidebarCollapsed)"
                @onclick="ToggleSidebar">
            <span aria-hidden="true">@(_sidebarCollapsed ? "›" : "‹")</span>
            <span class="link-label">Collapse sidebar</span>
        </button>
    </aside>

    @if (_mobileSidebarOpen)
    {
        <button class="sidebar-overlay"
                type="button"
                aria-label="Close navigation"
                @onclick="CloseMobileSidebar"></button>
    }

    <div class="shell-main">
        <header class="topbar">
            <button class="mobile-menu-button"
                    type="button"
                    aria-label="Open navigation"
                    aria-controls="portal-sidebar"
                    aria-expanded="@_mobileSidebarOpen"
                    @onclick="ToggleMobileSidebar">
                <span aria-hidden="true">☰</span>
            </button>

            <label class="global-search" style="visibility:hidden">
                <span class="visually-hidden">Search the learning portal</span>
                <span aria-hidden="true">⌕</span>
                <input type="search" placeholder="Search courses, people, and resources" />
            </label>

            <div class="topbar-actions">
                <button class="icon-button" style="display:none" type="button" aria-label="Theme options" title="Theme options">
                    <span aria-hidden="true">◐</span>
                </button>
                <button class="icon-button notification-button" style="display:none" type="button" aria-label="Notifications" title="Notifications">
                    <span aria-hidden="true">♢</span>
                    <span class="notification-indicator" aria-hidden="true"></span>
                </button>

                <AuthorizeView>
                    <Authorized Context="authorizationContext">
                        @{
                            var displayName = GetDisplayName(authorizationContext.User);
                        }
                        @if (_accountMenuOpen)
                        {
                            <button class="account-menu-dismiss" type="button"
                                    aria-label="Close account menu"
                                    @onclick="CloseAccountMenu"></button>
                        }
                        <div class="account-menu-container" @onkeydown="HandleAccountMenuKey">
                        <button class="profile-button" type="button"
                                aria-label="Open account menu" aria-haspopup="menu"
                                aria-expanded="@_accountMenuOpen" @onclick="ToggleAccountMenu">
                            <span class="avatar">@GetInitials(displayName)</span>
                            <span class="profile-copy">
                                <strong>@displayName</strong>
                                <small>@GetPrimaryRole(authorizationContext.User)</small>
                            </span>
                            <span aria-hidden="true">⌄</span>
                        </button>
                        @if (_accountMenuOpen)
                        {
                            <div class="account-menu" role="menu">
                                <div class="account-menu-identity">
                                    <strong>@displayName</strong>
                                    <small>@GetEmail(authorizationContext.User)</small>
                                </div>
                                <a role="menuitem" href="/profile">Profile</a>
                                <a role="menuitem" href="/my-learning">My Learning</a>
                                <a role="menuitem" href="/ai-tutor">AI Tutor</a>
                                @if (authorizationContext.User.IsInRole(ApplicationRoles.Administrator))
                                {
                                    <a role="menuitem" href="/users">Administration</a>
                                }
                                <form method="post" action="/auth/logout">
                                    <AntiforgeryToken />
                                    <button role="menuitem" type="submit">Sign out</button>
                                </form>
                            </div>
                        }
                        </div>
                    </Authorized>
                    <NotAuthorized>
                        <div class="guest-actions" aria-label="Guest account actions">
                            <a class="button button-primary" href="@GuestSignInUrl">Sign in</a>
                            <a class="button guest-register" href="@GuestRegisterUrl">Register</a>
                        </div>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </header>

        <main class="page-content">
            @Body
        </main>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _sidebarCollapsed;
    private bool _mobileSidebarOpen;
    private bool _accountMenuOpen;

    private string CurrentLocalUrl =>
        AuthenticationNavigation.ResolveCurrentReturnUrl(
            Navigation.BaseUri,
            Navigation.Uri);

    private string GuestSignInUrl =>
        AuthenticationNavigation.BuildSignInUrl(CurrentLocalUrl);

    private string GuestRegisterUrl =>
        AuthenticationNavigation.BuildRegisterUrl(CurrentLocalUrl);

    private void ToggleSidebar() => _sidebarCollapsed = !_sidebarCollapsed;

    private void ToggleMobileSidebar() => _mobileSidebarOpen = !_mobileSidebarOpen;

    private void CloseMobileSidebar() => _mobileSidebarOpen = false;

    private void ToggleAccountMenu() => _accountMenuOpen = !_accountMenuOpen;

    private void CloseAccountMenu() => _accountMenuOpen = false;

    private void HandleAccountMenuKey(KeyboardEventArgs args)
    {
        if (args.Key == "Escape")
        {
            CloseAccountMenu();
        }
    }

    private static string GetDisplayName(ClaimsPrincipal user) =>
        user.FindFirstValue(ApplicationClaimTypes.DisplayName)
        ?? user.FindFirstValue(ClaimTypes.Name)
        ?? user.Identity?.Name
        ?? "Portal User";

    private static string GetPrimaryRole(ClaimsPrincipal user) =>
        user.FindFirstValue(ApplicationClaimTypes.Role)
        ?? user.FindFirstValue(ClaimTypes.Role)
        ?? "Member";

    private static string GetEmail(ClaimsPrincipal user) =>
        user.FindFirstValue(ApplicationClaimTypes.Email)
        ?? user.FindFirstValue(ClaimTypes.Email)
        ?? string.Empty;

    private static string GetInitials(string displayName)
    {
        var initials = displayName
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Take(2)
            .Select(part => char.ToUpperInvariant(part[0]))
            .ToArray();

        return initials.Length == 0 ? "LP" : new string(initials);
    }
}
