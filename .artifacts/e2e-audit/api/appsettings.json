{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=LearningPortal;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "InstructorEligibility": {
    "QualificationThreshold": 80
  },
  "Ollama": {
    "BaseUrl": "http://localhost:11434",
    "Model": "llama3.2:3b",
    "RequestTimeoutSeconds": 120,
    "MaxContextCharacters": 30000,
    "MaxQuestionCharacters": 2000,
    "MaxConversationMessages": 20,
    "Temperature": 0.2,
    "Enabled": true
  },
  "DevelopmentSeed": {
    "Enabled": false
  },
  "DatabaseInitialization": {
    "ApplyMigrations": false
  },
  "Jwt": {
    "Issuer": "LearningPortal.Api",
    "Audience": "LearningPortal.Clients",
    "SigningKey": "",
    "ExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 30
  },
  "Cors": {
    "AllowedOrigins": [
      "https://localhost:7080",
      "http://localhost:5080"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*"
}
